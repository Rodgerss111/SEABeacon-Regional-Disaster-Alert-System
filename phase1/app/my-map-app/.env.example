# SEABeacon frontend (Vite) — template. Copy to ".env" and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.
# Anon keys are PUBLIC by design (shipped in the browser bundle); rely on
# Supabase Row Level Security for real protection.

# AI1 — flood
VITE_AI1_SUPABASE_URL=https://your-ai1-project.supabase.co
VITE_AI1_SUPABASE_ANON_KEY=your-ai1-anon-key

# AI2 — typhoon (XGBoost/LSTM forecasts)
VITE_AI2_SUPABASE_URL=https://your-ai2-project.supabase.co
VITE_AI2_SUPABASE_ANON_KEY=your-ai2-anon-key

# AI3 — social/NLP
VITE_AI3_SUPABASE_URL=https://your-ai3-project.supabase.co
VITE_AI3_SUPABASE_ANON_KEY=your-ai3-anon-key

# Central report database
VITE_CENTRAL_SUPABASE_URL=https://your-central-project.supabase.co
VITE_CENTRAL_SUPABASE_ANON_KEY=your-central-anon-key
