# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file — it is already in .gitignore.

# Component A's own Supabase project
# (Project Settings -> API in your Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# Read-only key for Component B's Supabase project (typhoon forecasts)
# Ask the Component B owner for this key.
COMPONENT_B_ANON_KEY=component-b-anon-key-here
