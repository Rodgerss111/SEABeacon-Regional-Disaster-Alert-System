# SEABeacon — xgboost_forecast service. Copy to ".env" and fill in real values.
# Never commit the real ".env".

# Local PostGIS container (spatial intersection queries) — api/main.py
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/spatial_db

# Supabase Postgres (direct/pooler connection) — api/main.py forecast logging
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Supabase REST API (integration/lstm_connect.py)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ANON_KEY=your-anon-key
