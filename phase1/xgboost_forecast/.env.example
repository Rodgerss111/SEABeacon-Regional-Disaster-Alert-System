# SEABeacon environment variables
# Copy to .env and fill in your Telegram bot token (from @BotFather).

TELEGRAM_BOT_TOKEN=

# Backend
DATABASE_URL=sqlite:///./seabeacon.db
API_BASE_URL=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Free public MapLibre style. Replace with your own MapTiler / Stadia key for production.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
